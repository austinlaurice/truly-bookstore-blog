source "https://rubygems.org"

# 本機預覽用。
#
# 注意：正式建置是 GitHub Pages 原生環境（Jekyll 3.9 + safe mode 白名單 plugins），
# 但 github-pages gem 的舊版相依套件無法在新版 Ruby（3.2+）上執行，
# 所以本機改用 Jekyll 4 預覽——本站只使用白名單 plugins 與核心 Liquid 功能，
# 兩個版本的建置結果一致。
gem "jekyll", "~> 4.3"
gem "jekyll-feed"
gem "jekyll-seo-tag"
gem "webrick"
